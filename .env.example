# Copy to .env and fill in. .env is gitignored; THIS file is committed —
# it documents the shape of the config, so never put a real key here.
# Both services are free and neither asks for a card.

# https://console.groq.com/keys
GROQ_API_KEY=

# https://app.tavily.com  (free tier: 1000 searches/month)
TAVILY_API_KEY=

# Free-tier default. Must be a model that reliably emits tool calls —
# llama-3.3-70b is NOT one (fails ~7/8 on the search schema). The free tier's
# real cap is tokens/min: scout has 30k, gpt-oss-120b only 8k (too small).
MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# How many times the critic may send the report back before it ships.
# Each revision is another writer + critic call, so this is the main cost knob.
MAX_REVISIONS=2

# LLM-as-judge coverage check. Costs one extra call per run; the rule-based
# citation checks always run and are free.
USE_LLM_JUDGE=true
